# Required - get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional - narration via Microsoft Edge's free neural TTS (no API key,
# needs network access). Leave blank to use the defaults shown below, or
# pick other voices from Microsoft's Edge "Read Aloud" voice list.
# Leave the app with no narration at all by making synthesizeNarration
# unreachable - not normally needed, narration just falls back to silent/
# caption-only mode automatically if synthesis fails.
EDGE_TTS_VOICE_FEMALE=en-US-AriaNeural
EDGE_TTS_VOICE_MALE=en-US-GuyNeural

# Pollinations.ai needs no key - it's free and open
POLLINATIONS_BASE_URL=https://image.pollinations.ai/prompt

# Optional - free background music. Drop a few royalty-free mp3/wav tracks in
# a folder and point this at it; one is picked at random per reel and mixed
# in quietly under the narration. Leave blank to skip music entirely.
MUSIC_DIR=
MUSIC_VOLUME=0.18

# Optional - burned-in captions use this font automatically if found. Leave
# blank to use the bundled backend/fonts/DejaVuSans-Bold.ttf (works on every
# OS, including Railway's Linux containers). Only set this if you want a
# different font.
CAPTION_FONT_PATH=

PORT=4000

# Allowed origin for CORS in production - set this to your Vercel frontend's
# URL (e.g. https://storyforge.vercel.app). Leave blank to allow all origins
# (fine for local dev/testing, not recommended once this is public).
FRONTEND_URL=

# --- Cloud storage (Cloudflare R2) - optional, recommended for production ---
# Stores each reel's finished output.mp4 in R2 instead of only local disk,
# so it survives Railway restarts/redeploys and serves from R2's edge.
# Leave all four blank to fall back to serving videos from local disk via
# the /media route (fine for local dev).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public base URL for the bucket - enable "Public Access" on the R2 bucket
# to get a *.r2.dev URL, or map a custom domain to it. No trailing slash.
R2_PUBLIC_URL=

# --- Database (Postgres) - optional, recommended for production ---
# When deployed on Railway with the Postgres plugin attached, Railway sets
# this automatically. Leave blank to fall back to the local
# storage/feed.json flat file (fine for local dev).
DATABASE_URL=
