# Required - get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional - free, self-hosted, no API key, no usage caps.
# Download Piper from https://github.com/rhasspy/piper/releases and voice
# models from https://github.com/rhasspy/piper/blob/master/VOICES.md
# Leave blank to run in caption-only mode (no narration audio).
PIPER_EXECUTABLE=
PIPER_VOICE_FEMALE=
PIPER_VOICE_MALE=

# Pollinations.ai needs no key - it's free and open
POLLINATIONS_BASE_URL=https://image.pollinations.ai/prompt

# Optional - free background music. Drop a few royalty-free mp3/wav tracks in
# a folder and point this at it; one is picked at random per reel and mixed
# in quietly under the narration. Leave blank to skip music entirely.
MUSIC_DIR=
MUSIC_VOLUME=0.18

# Optional - burned-in captions use this font automatically if found.
# Most Windows machines already have this font, so you usually don't need
# to set it.
CAPTION_FONT_PATH=C:/Windows/Fonts/arialbd.ttf

PORT=4000
